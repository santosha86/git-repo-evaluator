# GitHub API token (optional but strongly recommended)
# Without a token: 60 requests/hour. With a token: 5,000 requests/hour.
# Create one at: https://github.com/settings/tokens?type=beta
# Required scopes: public_repo (read-only is enough for public repos)
GITHUB_TOKEN=

# Anthropic API key (only required when using --deep flag)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# API server
API_HOST=127.0.0.1
API_PORT=8000

# Data directory (relative to project root)
DATA_DIR=./data
